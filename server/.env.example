# --- SMTP / Email settings for the Contact Us form ---
# Copy this file to ".env" (same folder) and fill in your real values.
# The .env file is gitignored and never committed.

# For Gmail: use an App Password (https://myaccount.google.com/apppasswords),
# NOT your normal login password. 2-Step Verification must be enabled first.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-16-char-app-password

# "From" header shown to recipients (optional — defaults to BRAND_NAME <SMTP_USER>)
MAIL_FROM=MySoulTrip <your-gmail-address@gmail.com>

# Where team notifications of new enquiries are sent (optional — defaults to SMTP_USER)
MAIL_TO=info@mysoultrip.in

# Brand name used in the email subject/body
BRAND_NAME=MySoulTrip
